meta {
  name: 10 Me After Logout
  type: http
  seq: 10
}

get {
  url: {{gateway_url}}/v1/users/me
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
  Accept-Language: en
}

tests {
  test("revoked token is rejected", function() {
    expect(res.getStatus()).to.equal(401);
  });
}

docs {
  The access token revoked at logout must no longer authenticate.
}
