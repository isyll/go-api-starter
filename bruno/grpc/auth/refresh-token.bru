meta {
  name: Refresh Token
  type: grpc
  seq: 3
}

grpc {
  url: {{grpc_url}}
  method: /auth.v1.AuthService/RefreshToken
  body: grpc
  auth: none
  methodType: unary
}

metadata {
  accept-language: en
}

body:grpc {
  name: message
  content: '''
  {
    "refreshToken": "{{refresh_token}}"
  }
  '''
}

docs {
  Rotates the refresh token. Reusing a consumed token returns 401 and revokes the whole family. Public.
  
  gRPC method: /auth.v1.AuthService/RefreshToken
}
