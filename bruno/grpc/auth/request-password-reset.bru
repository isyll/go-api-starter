meta {
  name: Request Password Reset
  type: grpc
  seq: 7
}

grpc {
  url: {{grpc_url}}
  method: /auth.v1.AuthService/RequestPasswordReset
  body: grpc
  auth: none
  methodType: unary
}

metadata {
  accept-language: en
}

body:grpc {
  name: message
  content: '''
  {
    "email": "{{test_email}}"
  }
  '''
}

docs {
  Always returns 200 (no account enumeration). Sends a reset email when the account exists. Public.
  
  gRPC method: /auth.v1.AuthService/RequestPasswordReset
}
